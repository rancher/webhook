{
	"version": "2",
	"linters": {
		"default": "none",
		"enable": [
			"govet",
			"revive",
			"misspell",
			"ineffassign"
		],
		"settings": {
			"revive": {
				"rules": [
					{"name": "exported", "disabled": true},
					{"name": "package-comments", "disabled": true}
				]
			}
		},
		"exclusions": {
			"paths": [
				"pkg/generated"
			]
		}
	},
	"formatters": {
		"enable": [
			"goimports",
			"gofmt"
		],
		"exclusions": {
			"paths": [
				"pkg/generated"
			]
		}
	},
	"run": {
		"timeout": "10m"
	}
}
