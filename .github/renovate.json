{
  "extends": [
    "github>rancher/renovate-config#release"
  ],
  "baseBranchPatterns": [
    "main",
    "release/v0.9",
    "release/v0.8",
    "release/v0.7",
    "release/v0.6"
  ],
  "prHourlyLimit": 2,
  "enabledManagers": [
    "dockerfile",
    "github-actions",
    "helm-values",
    "custom.regex",
    "gomod"
  ],
  "packageRules": [
    {
      "enabled": false,
      "matchPackageNames": [
        "/go.opentelemetry.io/*/",
        "/github.com/prometheus/*/",
        "/github.com/rancher/rancher/pkg/apis/",
        "github.com/rancher/lasso",
        "github.com/rancher/wrangler/v3",
        "github.com/rancher/dynamiclistener"
      ]
    },
    {
      "matchUpdateTypes": [
        "patch"
      ],
      "matchPackageNames": [
        "/k8s.io/*/",
        "/sigs.k8s.io/*/"
      ]
    },
    {
      "enabled": false,
      "matchUpdateTypes": [
        "major",
        "minor"
      ],
      "matchPackageNames": [
        "/k8s.io/*/",
        "/sigs.k8s.io/*/"
      ]
    }
  ]
}
