{
  "extends": [
    "github>rancher/renovate-config#release"
  ],
  "baseBranchPatterns": [
    "main",
    "release/v0.9",
    "release/v0.8",
    "release/v0.7",
    "release/v0.6"
  ],
  "prHourlyLimit": 2,
  "enabledManagers": [
    "droneci",
    "dockerfile",
    "github-actions",
    "helm-values",
    "custom.regex",
    "gomod"
  ],
  "packageRules": [
    {
      "enabled": false,
      "matchPackageNames": [
        "/go.opentelemetry.io/*/",
        "/github.com/prometheus/*/",
        "/github.com/rancher/rancher/pkg/apis/",
        "github.com/rancher/lasso",
        "github.com/rancher/wrangler/v3",
        "github.com/rancher/dynamiclistener"
      ]
    },
    {
      "matchUpdateTypes": [
        "patch"
      ],
      "matchPackageNames": [
        "/k8s.io/*/",
        "/sigs.k8s.io/*/"
      ]
    },
    {
      "enabled": false,
      "matchUpdateTypes": [
        "major",
        "minor"
      ],
      "matchPackageNames": [
        "/k8s.io/*/",
        "/sigs.k8s.io/*/"
      ]
    },
    {
      "description": "Disable major updates on release branches",
      "matchUpdateTypes": ["major"],
      "matchBaseBranches": ["/^release\\//"],
      "enabled": false
    },
    {
      "description": "Group all GitHub Actions updates into a single PR per branch",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "separateMajorMinor": false
    },
    {
      "description": "Group Go dev tooling (Go version, golangci-lint, helm) into a single PR per branch",
      "matchPackageNames": [
        "go",
        "golangci/golangci-lint",
        "helm/helm"
      ],
      "groupName": "Go dev tools",
      "separateMajorMinor": false
    },
    {
      "description": "Group golang.org/x/* packages into a single PR per branch",
      "matchPackageNames": [
        "/golang.org/x/*/"
      ],
      "groupName": "golang.org/x packages"
    },
    {
      "description": "Group SUSE BCI base image updates into a single PR per branch",
      "matchPackageNames": [
        "/registry.suse.com/bci/*/"
      ],
      "groupName": "BCI base images"
    }
  ]
}
